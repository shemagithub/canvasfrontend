# Production API (HTTPS required)
VITE_API_URL=https://backend.canvastoursafrica.com

# Public marketing site URL (canonical links, Open Graph, sitemap)
VITE_SITE_URL=https://canvastoursafrica.com

# Vite dev-server proxy when VITE_API_URL is empty (see vite.config.ts)
VITE_API_PROXY_TARGET=https://backend.canvastoursafrica.com
